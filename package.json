{
  "name": "android-device-manager",
  "version": "1.0.0",
  "description": "QA Manager - ADB/scrcpy 기반 QA 도구",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win portable",
    "build:mac": "electron-builder --mac dir",
    "build:linux": "electron-builder --linux AppImage",
    "build:installer": "electron-builder --win nsis"
  },
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.overdare.device-manager",
    "productName": "QA Manager",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "webview-preload.js",
      "src/**/*",
      "lib/**/*",
      "assets/**/*"
    ],
    "asarUnpack": [
      "webview-preload.js"
    ],
    "extraResources": [
      {
        "from": "vendor/scrcpy",
        "to": "scrcpy",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/qa-icon.ico",
      "sign": false,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/qa-icon.ico",
      "artifactName": "AndroidDeviceManager-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "AndroidDeviceManager-Portable.exe"
    },
    "mac": {
      "target": [
        "dir"
      ],
      "identity": null
    }
  },
  "devDependencies": {
    "electron": "^41.0.4",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "node-pty": "^1.1.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-search": "^0.13.0",
    "xterm-addon-web-links": "^0.9.0"
  }
}
